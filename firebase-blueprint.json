{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "avatar": { "type": "string", "description": "URL to user avatar" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Financial bill or debt",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the bill" },
        "name": { "type": "string", "description": "Name of the bill or person" },
        "amount": { "type": "number", "description": "Amount involved" },
        "type": { "type": "string", "enum": ["Eu devo", "Me devem"], "description": "Type of debt" },
        "description": { "type": "string", "description": "Details about the debt" },
        "imageUrl": { "type": "string", "description": "Base64 or URL of the photo" },
        "dueDate": { "type": "string", "format": "date", "description": "Due date (YYYY-MM-DD)" },
        "paidDate": { "type": "string", "format": "date", "description": "Date when paid (YYYY-MM-DD)" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"], "description": "Current status" },
        "uid": { "type": "string", "description": "Owner's user ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "amount", "type", "dueDate", "status", "uid"]
    },
    "Income": {
      "title": "Income",
      "description": "User income source",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the income" },
        "name": { "type": "string", "description": "Source of income" },
        "amount": { "type": "number", "description": "Amount received" },
        "category": { "type": "string", "description": "Category of income" },
        "date": { "type": "string", "format": "date", "description": "Date received (YYYY-MM-DD)" },
        "uid": { "type": "string", "description": "Owner's user ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "amount", "category", "date", "uid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/bills/{billId}": {
      "schema": "Bill",
      "description": "User financial bills"
    },
    "/incomes/{incomeId}": {
      "schema": "Income",
      "description": "User income records"
    }
  }
}
